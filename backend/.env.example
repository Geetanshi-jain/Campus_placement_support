SECRET_KEY=django-insecure-change-this-to-a-real-random-secret-key-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Gemini API
GEMINI_API_KEY=your_gemini_api_key_here

# Voyage AI Embeddings (optional — leave blank to use sentence-transformers locally)
VOYAGE_API_KEY=
EMBEDDING_BACKEND=sentence_transformers

# Gemini model
GEMINI_MODEL=gemini-2.5-flash
